# Image generation (sprite scripts only — never shipped to the browser).
OPENAI_API_KEY=sk-...

# ElevenLabs text-to-speech (read server-side by the /api/tts dev proxy; never bundled).
# Without these the app falls back to the built-in Web Speech voice.
ELEVENLABS_API_KEY=sk-...
# Optional overrides:
# ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku   # default: "Lily" (soft, warm British storyteller)
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5      # default: low-latency model with timestamps
